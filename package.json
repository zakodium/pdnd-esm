{
  "name": "@zakodium/pdnd-esm",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Re-export specific methods from @atlaskit/pragmatic-drag-and-drop for ESM compatibility",
  "keywords": [],
  "author": "Michael Zasso",
  "type": "module",
  "exports": {
    ".": "./lib/index.cjs"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "clean": "rimraf coverage lib",
    "eslint": "eslint .",
    "eslint-fix": "eslint . --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "test": "npm run test-only && npm run check-types && npm run eslint && npm run prettier",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.7",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.2",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@zakodium/tsconfig": "^1.0.2",
    "eslint": "^9.37.0",
    "eslint-config-cheminfo-typescript": "^20.0.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zakodium/@zakodium/pdnd-esm.git"
  },
  "bugs": {
    "url": "https://github.com/zakodium/@zakodium/pdnd-esm/issues"
  },
  "homepage": "https://github.com/zakodium/@zakodium/pdnd-esm#readme"
}
